<div class="row-fluid">
    <div class="tabbable">
        <h4>OctoHue Settings <small>Version {{ plugin_octohue_version }}</small></h4>
		<ul class="nav nav-tabs" id="octohue_tabs">
			<li class="active"><a data-toggle="tab" href="#octohue_settings_bridge">Bridge</a></li>
			<li><a data-toggle="tab" href="#octohue_settings_general">General</a></li>
			<li><a data-toggle="tab" href="#octohue_settings_lights">Lights</a></li>
			<li><a data-toggle="tab" href="#octohue_settings_power">Power</a></li>
		</ul>
        <div class="tab-content">
            <div id="octohue_settings_bridge" class="tab-pane active">
                <div class="control-group">

                    <!-- Provider selector -->
                    <div class="control-group" style="margin-bottom: 8px;">
                        <label class="control-label">{{ _('Light Controller') }}</label>
                        <div class="controls">
                            <select class="input-medium" data-bind="value: ownSettings.provider">
                                <option value="hue">Philips Hue</option>
                                <option value="wled">WLED</option>
                            </select>
                        </div>
                    </div>

                    <!-- Hue configuration -->
                    <div data-bind="visible: ownSettings.provider() === 'hue'">
                        Hue Bridge Status: <span id="huebridgestatus" class="badge badge-danger" style="background-color: #ff4b4b;">Unconfigured</span>
                        <div id="huebridge_unconfigured">
                            <h4 id="pairbridge">Pair with your Hue Bridge</h4>
                            <button id="huebridge_startsearch" type="button" class="btn" data-bind="click: bridgediscovery"><i class="fa fa-search"></i> Find My Bridge</button>
                            <br /><br />
                            <span id="huebridge_searchstatus" class="inactiveconfig"></span>
                            <br />
                            <div id="huebridge_found" class="inactiveconfig">
                                <p>Click on "Start Pairing" button below and push the pairing button on your Bridge</p>
                                <button id="huebridge_pairingbutton" class="btn" data-bind="click: bridgepair"><i class="fa fa-link"></i> Start Pairing</button>
                                <span id="huebridge_pairingreties"></span>
                                <br />
                                <img src="plugin/octohue/static/images/huebridge.png" />
                                <div id="huebridge_paired_actions" class="inactiveconfig" style="margin-top: 12px;">
                                    <button class="btn btn-success" data-bind="click: goToLights"><i class="fa fa-lightbulb-o"></i> Select your light &rarr;</button>
                                </div>
                            </div>
                        </div>

                        <div id="huebridge_configured">
                            <label class="control-label">{{ _('Hue Bridge Address') }}</label>
                            <div class="controls">
                                <input id="bridgeaddress" type="text" class="input-block-level" data-bind="value: ownSettings.bridgeaddr">
                            </div>
                            <label class="control-label">{{ _('Hue Username') }}</label>
                            <div class="controls">
                                <input id="apikey" type="text" class="input-block-level" data-bind="value: ownSettings.husername">
                            </div>
                        </div>
                    </div>

                    <!-- WLED configuration -->
                    <div data-bind="visible: ownSettings.provider() === 'wled'">
                        <label class="control-label">{{ _('WLED Controller Address') }}</label>
                        <div class="controls">
                            <input type="text" class="input-block-level" placeholder="192.168.1.x" data-bind="value: ownSettings.bridgeaddr">
                        </div>
                        <span class="help-block">Enter the IP address or hostname of your WLED controller.</span>
                    </div>

                </div>
            </div>
            
            <div id="octohue_settings_general" class="tab-pane">
                <div class="control-group">
                    <h4>General Behaviour</h4>
                    <div class="control-group">
                        <label class="control-label"></label>
                        <div class="controls">
                            <label class="checkbox">
                                <input type="checkbox" data-bind="checked: ownSettings.offonshutdown">Lights Off on Server Shutdown
                            </label>
                        </div>
                        <div class="controls">
                            <label class="checkbox">
                                <input type="checkbox" data-bind="checked: ownSettings.ononstartup">Lights On on OctoPrint Startup
                            </label>
                            <select class="input-block-level" data-bind="value: ownSettings.ononstartupevent, options: $root.settingsViewModel.settings.plugins.octohue.configuredEvents().sort(), optionsCaption: 'Select Event', valueAllowUnset: true"></select>
                        </div>
                        <label class="control-label"></label>
                        <div class="controls">
                            <label class="checkbox">
                                <input type="checkbox" data-bind="checked: ownSettings.showhuetoggle">Add Light Toggle Icon to Navigation Bar
                            </label>
                            <div data-bind="visible: ownSettings.showhuetoggle()" style="margin-top: 6px; margin-left: 20px;">
                                <label class="control-label" style="text-align: left; width: auto;">Toggle-on colour &amp; brightness</label>
                                <div style="margin-top: 4px;">
                                    <button type="button" class="btn btn-mini" style="width: 40px" data-bind="click: toggleToggleCtMode, css: { active: ownSettings.togglect() }"><span data-bind="text: ownSettings.togglect() ? 'CT' : 'RGB'"></span></button>
                                    <span data-bind="visible: !ownSettings.togglect()">
                                        <input type="color" class="colour-picker" data-bind="value: ownSettings.togglecolour">
                                        <input type="text" class="input-mini" data-bind="value: ownSettings.togglecolour" style="width: 70px">
                                    </span>
                                    <span data-bind="visible: ownSettings.togglect()">
                                        <input type="range" min="153" max="500" class="ct-slider" style="width: 120px" data-bind="value: ownSettings.togglect">
                                    </span>
                                    <input type="number" min="1" max="100" class="input-mini" data-bind="value: ownSettings.togglebri" style="width: 45px">
                                    <span class="help-inline">%</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <hr>
                    <h4>Night Mode</h4>
                    <div class="control-group">
                        <div class="controls">
                            <label class="checkbox">
                                <input type="checkbox" data-bind="checked: ownSettings.nightmode_enabled">Enable Night Mode
                            </label>
                        </div>
                        <div data-bind="visible: ownSettings.nightmode_enabled()">
                            <div class="controls" style="margin-top: 8px">
                                <label class="control-label">{{ _('Active between') }}</label>
                                <input type="time" class="input-mini" style="width: 100px" data-bind="value: ownSettings.nightmode_start">
                                <span>&nbsp;and&nbsp;</span>
                                <input type="time" class="input-mini" style="width: 100px" data-bind="value: ownSettings.nightmode_end">
                            </div>
                            <div class="controls" style="margin-top: 8px">
                                <label class="control-label">{{ _('During night mode') }}</label>
                                <label class="radio">
                                    <input type="radio" value="pause" data-bind="checked: ownSettings.nightmode_action"> Pause all light changes
                                </label>
                                <label class="radio">
                                    <input type="radio" value="dim" data-bind="checked: ownSettings.nightmode_action"> Limit brightness only
                                </label>
                            </div>
                            <div class="controls" data-bind="visible: ownSettings.nightmode_action() === 'dim'" style="margin-top: 4px">
                                <label class="control-label">{{ _('Max brightness') }}</label>
                                <input type="number" min="1" max="100" class="input-mini" data-bind="value: ownSettings.nightmode_maxbri" style="width: 60px">
                                <span class="help-inline">1–100%</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div id="octohue_settings_lights" class="tab-pane">
                <div class="light_options">
                    <label class="control-label" data-bind="text: ownSettings.provider() === 'hue' ? 'Hue Light or Group' : 'WLED Controller'"></label>
                    <div class="controls">
                        <select class="input-block-level" data-bind="value: ownSettings.lampid, options: hueLamps, optionsText: 'name', optionsValue: 'id', optionsCaption: 'Select light or group', valueAllowUnset: true"></select>
                    </div>
                    <label class="control-label">{{ _('Default Brightness') }}</label>
                    <div class="controls">
                        <input type="number" min="1" max="100" class="input-mini" data-bind="value: ownSettings.defaultbri">
                        <span class="help-inline">1–100%</span>
                    </div>
                    <div>
                        <small>
                            <a href="#" class="muted" data-bind="toggleContent: { class: 'fa-caret-right fa-caret-down', parent: '.light_options', container: '.hide' }"><i class="fas fa-caret-right"></i> {{ _(' Event Lighting Options') }}</a>
                        </small>
                    </div>
                    <div class="hide">
                        <div class="control-group">
                            <h4>Status Colours</h4>
                            <div>
                                <table class="table table-striped table-condensed">
                                    <thead>
                                        <tr>
                                            <th style="width: 155px">Status</th>
                                            <th style="width: 165px">Colour / Temp</th>
                                            <th style="width: 50px"><abbr title="Brightness (1–100%)">Bri%</abbr></th>
                                            <th style="width: 60px"><abbr title="Delay in seconds before the light change fires">Delay (s)</abbr></th>
                                            <th style="width: 40px; text-align: center"><abbr data-bind="attr: { title: ownSettings.provider() === 'hue' ? 'Flash: trigger a 15-second alert cycle' : 'Flash: not supported by WLED' }">Flash</abbr></th>
                                            <th style="width: 40px; text-align: center"><abbr title="Switch off after the event">Off</abbr></th>
                                            <th style="width: 40px; text-align: center"><abbr title="Remove this entry">Del</abbr></th>
                                        </tr>
                                    </thead>
                                    <tbody class="control-group" data-bind="foreach: statusDict">
                                        <tr>
                                            <td><select class="input-block-level" data-bind="value: event, options: $root.settingsViewModel.settings.plugins.octohue.availableEvents().sort(), optionsCaption: 'Select Event', valueAllowUnset: true"></select></td>
                                            <td>
                                                <button type="button" class="btn btn-mini" style="width: 40px" data-bind="click: $parent.toggleCtMode, css: { active: ct() }"><span data-bind="text: ct() ? 'CT' : 'RGB'"></span></button>
                                                <span data-bind="visible: !ct()">
                                                    <input type="color" class="colour-picker" data-bind="value: colour">
                                                    <input type="text" class="input-mini" data-bind="value: colour" style="width: 60px">
                                                </span>
                                                <span data-bind="visible: ct()">
                                                    <input type="range" min="153" max="500" class="ct-slider" style="width: 110px" data-bind="value: ct">
                                                </span>
                                            </td>
                                            <td><input type="number" min="1" max="100" class="input-mini" data-bind="value: brightness" style="width: 40px"></td>
                                            <td><input type="number" min="0" class="input-mini" data-bind="value: delay" style="width: 45px"></td>
                                            <td style="text-align: center"><i data-bind="attr: { class: flash() ? 'fa fa-bell' : 'fa fa-bell-o' }, click: $parent.setFlash"></i></td>
                                            <td style="text-align: center"><i data-bind="attr: { class: turnoff() ? 'fa fa-check-square-o' : 'fa fa-square-o' }, click: $parent.setSwitchOff"></i></td>
                                            <td style="text-align: center"><i class="fa fa-trash-o" data-bind="click: $parent.removeStatus"></i></td>
                                        </tr>
                                    </tbody>
                                </table>
                                <div class="control">
                                    <button class="btn" data-bind="click: addNewStatus">New</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div id="octohue_settings_power" class="tab-pane">
                <div class="power-options" data-bind="visible: ownSettings.provider() === 'hue'">
                    <p class="muted" data-bind="visible: ownSettings.provider() !== 'hue'" style="display:none;">Power control is only available with Philips Hue.</p>
                    <label class="checkbox">
                        <input type="checkbox" data-bind="checked: ownSettings.showpowertoggle">Add Power Toggle Icon to Navigation Bar
                    </label>
                    <label class="control-label">{{ _('Hue Plug ID') }}</label>
                    <div class="controls">
                        <select class="input-block-level" data-bind="value: ownSettings.plugid, options: huePlugs, optionsText: 'name', optionsValue: 'id', optionsCaption: 'Select Plug', valueAllowUnset: true"></select>
                    </div>
                    <label class="checkbox">
                        <input type="checkbox" data-bind="checked: ownSettings.autopoweroff">Power off printer after print (time and temperature, if both slowest value wins)
                    </label>
                    <div class="control-group" style="margin-top: 4px;">
                        <span>Temp (°C): </span><input type="number" max="255" class="input-mini" data-bind="value: ownSettings.powerofftemp" value="0">
                        <span style="margin-left: 8px;">Time (s): </span><input type="number" max="900" class="input-mini" data-bind="value: ownSettings.powerofftime" value="0">
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>
